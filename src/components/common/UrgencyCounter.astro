---
interface Props {
  spotsLeft?: number;
  showTimer?: boolean;
}

const { spotsLeft = 3, showTimer = true } = Astro.props;
---

<div class="urgency-counter">
  <!-- Spots Left Counter with spinning letters -->
  <div class="inline-flex items-center px-4 py-2 bg-red-500 text-white rounded-full text-sm font-bold mb-4 animate-pulse">
    <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
    </svg>
    <span class="spinning-text">Solo quedan {spotsLeft} cupos este mes</span>
  </div>
  
  {showTimer && (
    <div id="urgency-timer" class="text-center">
      <p class="text-sm text-white/90 mb-2">Oferta especial termina en:</p>
      <div class="flex items-center justify-center space-x-2 text-lg font-bold text-white">
        <span id="timer-hours" class="bg-white/20 px-3 py-1 rounded">00</span>
        <span>:</span>
        <span id="timer-minutes" class="bg-white/20 px-3 py-1 rounded">00</span>
        <span>:</span>
        <span id="timer-seconds" class="bg-white/20 px-3 py-1 rounded">00</span>
      </div>
    </div>
  )}
</div>

<script define:vars={{ showTimer }}>
  if (typeof window !== 'undefined') {
    // Set timer to 48 hours from now
    let endTime = new Date().getTime() + (48 * 60 * 60 * 1000);
    
    function updateTimer() {
      if (!showTimer) return;
      
      const timerEl = document.getElementById('urgency-timer');
      if (!timerEl) return;
      
      const now = new Date().getTime();
      const distance = endTime - now;
      
      if (distance < 0) {
        // Timer expired, reset to another 48 hours
        endTime = new Date().getTime() + (48 * 60 * 60 * 1000);
        return;
      }
      
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);
      
      const hoursEl = document.getElementById('timer-hours');
      const minutesEl = document.getElementById('timer-minutes');
      const secondsEl = document.getElementById('timer-seconds');
      
      if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
      if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
      if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
    }
    
    // Update every second
    if (showTimer) {
      setInterval(updateTimer, 1000);
      updateTimer(); // Initial call
    }
    
    // Create spinning letters effect
    const spinningTextEl = document.querySelector('.spinning-text');
    if (spinningTextEl) {
      const text = spinningTextEl.textContent || '';
      spinningTextEl.innerHTML = '';
      
      text.split('').forEach((char) => {
        const span = document.createElement('span');
        span.textContent = char === ' ' ? '\u00A0' : char;
        span.className = 'spinning-letter';
        spinningTextEl.appendChild(span);
      });
    }
  }
</script>

<style>
  .spinning-letter {
    animation: spinLetter 2s ease-in-out infinite;
    transform-origin: center;
    display: inline-block;
  }
  
  @keyframes spinLetter {
    0% {
      transform: rotateY(0deg) scale(1);
    }
    25% {
      transform: rotateY(90deg) scale(1.1);
    }
    50% {
      transform: rotateY(180deg) scale(1);
    }
    75% {
      transform: rotateY(270deg) scale(1.1);
    }
    100% {
      transform: rotateY(360deg) scale(1);
    }
  }
  
  /* Stagger animation for each letter */
  .spinning-letter:nth-child(1) { animation-delay: 0s; }
  .spinning-letter:nth-child(2) { animation-delay: 0.05s; }
  .spinning-letter:nth-child(3) { animation-delay: 0.1s; }
  .spinning-letter:nth-child(4) { animation-delay: 0.15s; }
  .spinning-letter:nth-child(5) { animation-delay: 0.2s; }
  .spinning-letter:nth-child(6) { animation-delay: 0.25s; }
  .spinning-letter:nth-child(7) { animation-delay: 0.3s; }
  .spinning-letter:nth-child(8) { animation-delay: 0.35s; }
  .spinning-letter:nth-child(9) { animation-delay: 0.4s; }
  .spinning-letter:nth-child(10) { animation-delay: 0.45s; }
  .spinning-letter:nth-child(11) { animation-delay: 0.5s; }
  .spinning-letter:nth-child(12) { animation-delay: 0.55s; }
  .spinning-letter:nth-child(13) { animation-delay: 0.6s; }
  .spinning-letter:nth-child(14) { animation-delay: 0.65s; }
  .spinning-letter:nth-child(15) { animation-delay: 0.7s; }
  .spinning-letter:nth-child(16) { animation-delay: 0.75s; }
  .spinning-letter:nth-child(17) { animation-delay: 0.8s; }
  .spinning-letter:nth-child(18) { animation-delay: 0.85s; }
  .spinning-letter:nth-child(19) { animation-delay: 0.9s; }
  .spinning-letter:nth-child(20) { animation-delay: 0.95s; }
  .spinning-letter:nth-child(21) { animation-delay: 1s; }
  .spinning-letter:nth-child(22) { animation-delay: 1.05s; }
  .spinning-letter:nth-child(23) { animation-delay: 1.1s; }
  .spinning-letter:nth-child(24) { animation-delay: 1.15s; }
  .spinning-letter:nth-child(25) { animation-delay: 1.2s; }
  .spinning-letter:nth-child(26) { animation-delay: 1.25s; }
  .spinning-letter:nth-child(27) { animation-delay: 1.3s; }
  .spinning-letter:nth-child(28) { animation-delay: 1.35s; }
  .spinning-letter:nth-child(29) { animation-delay: 1.4s; }
  .spinning-letter:nth-child(30) { animation-delay: 1.45s; }
</style>

