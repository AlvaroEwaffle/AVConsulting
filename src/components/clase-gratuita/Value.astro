---
const valuePoints = [
    {
        icon: "💡",
        title: "Conocimiento Validado",
        description: "Accede a estrategias probadas por más de 100 emprendedores digitales. Este conocimiento normalmente cuesta miles de dólares en cursos y mentoría."
    },
    {
        icon: "⚡",
        title: "Ahorra Tiempo y Dinero",
        description: "Evita meses de prueba y error y miles de dólares en herramientas innecesarias. Aprende exactamente qué funciona y qué no."
    },
    {
        icon: "🎯",
        title: "Claridad y Dirección",
        description: "Obtén un plan de acción claro y específico para tu idea. El valor de tener claridad y dirección es incalculable para tu proyecto."
    },
    {
        icon: "🤝",
        title: "Acceso Directo",
        description: "Interactúa directamente conmigo y resuelve tus dudas específicas. Una sesión de consultoría individual tiene un valor de $150 USD."
    }
];
---

<section class="py-16 px-4 bg-gradient-to-br from-[#2175a1] to-[#3ca6dd] text-white rounded-xl mt-8">
    <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
            💎 El Valor Real de Esta Clase
        </h2>
        
        <div class="grid md:grid-cols-2 gap-8 mb-12">
            {valuePoints.map(point => (
                <div class="bg-white/10 backdrop-blur-sm p-6 rounded-xl">
                    <h3 class="text-xl font-bold mb-4 flex items-center">
                        <span class="text-2xl mr-2">{point.icon}</span>
                        {point.title}
                    </h3>
                    <p class="text-white/90">
                        {point.description}
                    </p>
                </div>
            ))}
        </div>

        <div class="text-center bg-white/10 backdrop-blur-sm p-8 rounded-xl">
            <p class="mt-6 text-lg text-white/90">
                Todo este valor completamente gratis porque creo en ayudarte a dar el primer paso.
            </p>
        </div>
    </div>
</section> 