---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  ctaText: string;
  ctaHref: string;
  imageSrc?: string;
  socialProof?: string;
  clientLogos?: string[];
}

const { title, subtitle, description, ctaText, ctaHref, imageSrc, socialProof, clientLogos } = Astro.props;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden -mt-8 pt-8">
  <!-- Animated Background GIF -->
  <div class="absolute inset-0 -z-10">
    <img 
      src="/assets/AnimatedBackgroundPattern.gif" 
      alt="Patrón de fondo animado con diseño moderno" 
      class="w-full h-full object-cover opacity-10"
      loading="lazy"
    />
  </div>
  
  <!-- Background Video/Animation Placeholder -->
  <div class="absolute inset-0 bg-gradient-to-br from-blue-900 via-blue-800 to-indigo-900">
    <div class="absolute inset-0 bg-black/20"></div>
  </div>
  
  <!-- Animated background dots -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 left-10 w-2 h-2 bg-white/20 rounded-full animate-pulse"></div>
    <div class="absolute top-40 right-20 w-3 h-3 bg-white/30 rounded-full animate-ping"></div>
    <div class="absolute top-60 left-1/4 w-1 h-1 bg-white/40 rounded-full animate-bounce"></div>
    <div class="absolute top-80 right-1/3 w-2 h-2 bg-white/25 rounded-full animate-pulse"></div>
    <div class="absolute top-32 right-1/2 w-1.5 h-1.5 bg-white/35 rounded-full animate-ping"></div>
    <div class="absolute top-96 left-1/2 w-2.5 h-2.5 bg-white/20 rounded-full animate-bounce"></div>
    <div class="absolute top-1/4 right-1/4 w-1 h-1 bg-white/30 rounded-full animate-pulse"></div>
    <div class="absolute bottom-1/4 left-1/3 w-2 h-2 bg-white/25 rounded-full animate-ping"></div>
    <div class="absolute bottom-1/3 right-1/3 w-1.5 h-1.5 bg-white/40 rounded-full animate-bounce"></div>
  </div>
  
  <!-- Content -->
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class={imageSrc ? "grid lg:grid-cols-2 gap-12 items-center" : "max-w-4xl mx-auto"}>
      <!-- Text Content -->
      <div class={imageSrc ? "text-left" : "text-center"}>
        <!-- Badge de confianza -->
        <div class="inline-flex items-center px-4 py-2 bg-yellow-400 text-black rounded-full text-sm font-semibold mb-6">
          ⚡ Tu sistema funcionando en menos de 24 horas, garantizado
        </div>
        
        <!-- Título principal (H1) -->
        <h1 class="text-4xl lg:text-6xl font-bold text-white mb-6 leading-tight">
          {title}
        </h1>
        
        <!-- Subtítulo con refuerzo -->
        <p class="text-xl lg:text-2xl text-blue-100 mb-8 leading-relaxed">
          {subtitle}
        </p>
        
        <!-- Descripción -->
        <p class="text-lg text-gray-300 mb-10 leading-relaxed max-w-2xl">
          {description}
        </p>
        
        <!-- CTA Principal -->
        <div class="mb-8">
          <a 
            href={ctaHref}
            class="inline-block bg-yellow-400 hover:bg-yellow-500 text-black px-8 py-4 rounded-xl font-bold text-xl transition-all duration-200 transform hover:scale-105 hover:shadow-2xl shadow-lg"
          >
            {ctaText}
          </a>
        </div>
        
        <!-- Prueba social inmediata -->
        {socialProof && (
          <div class={imageSrc ? "text-center lg:text-left" : "text-center"}>
            <p class="text-white/80 text-lg mb-4">
              {socialProof}
            </p>
          </div>
        )}
        
        <!-- Logos de clientes -->
        {clientLogos && clientLogos.length > 0 && (
          <div class={`flex items-center space-x-6 opacity-60 ${imageSrc ? "justify-center lg:justify-start" : "justify-center"}`}>
            {clientLogos.map((logo) => (
              <img src={logo} alt={`Logo de cliente que confía en ${title}`} class="h-8 w-auto" loading="lazy" />
            ))}
          </div>
        )}
      </div>
      
      <!-- Image/Visual -->
      {imageSrc && (
        <div class="relative">
          <img 
            src={imageSrc} 
            alt={`${title} - ${subtitle}`}
            class="w-full h-auto rounded-2xl shadow-2xl"
            loading="eager"
            width="800"
            height="600"
          />
          <!-- Overlay de confianza -->
          <div class="absolute -bottom-4 -left-4 bg-white rounded-xl p-4 shadow-lg">
            <div class="text-center">
              <div class="text-2xl font-bold text-green-600">✓</div>
              <div class="text-xs text-gray-600">Garantizado</div>
            </div>
          </div>
          
          <!-- Floating dots around the image -->
          <div class="absolute -top-2 -left-2 w-1 h-1 bg-white/40 rounded-full animate-ping"></div>
          <div class="absolute -bottom-2 -right-2 w-1.5 h-1.5 bg-white/30 rounded-full animate-pulse"></div>
          <div class="absolute top-1/2 -right-2 w-1 h-1 bg-white/50 rounded-full animate-bounce"></div>
        </div>
      )}
    </div>
  </div>
  
  <!-- Animated Scroll Down Arrow -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-20">
    <a 
      href="#como-funciona" 
      class="flex flex-col items-center text-white/80 hover:text-white transition-colors duration-300 group"
      aria-label="Scroll down"
    >
      <span class="text-sm mb-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">Ver más</span>
      <svg 
        class="w-8 h-8 animate-bounce" 
        fill="none" 
        stroke="currentColor" 
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path 
          stroke-linecap="round" 
          stroke-linejoin="round" 
          stroke-width="2" 
          d="M19 14l-7 7m0 0l-7-7m7 7V3"
        ></path>
      </svg>
    </a>
  </div>
</section> 