---
interface Props {
  title?: string;
  subtitle?: string;
  screenshots?: Array<{
    src: string;
    alt: string;
    title: string;
    description: string;
  }>;
}

const { 
  title = "Ve cómo funciona InstaClientes",
  subtitle = "Mira el sistema en acción con ejemplos reales",
  screenshots = [
    {
      src: "/assets/demo-bot-response.png",
      alt: "Bot de Instagram respondiendo automáticamente",
      title: "Bot respondiendo DMs",
      description: "El bot responde automáticamente preguntas sobre precios, horarios y servicios 24/7"
    },
    {
      src: "/assets/demo-fidelidapp.png",
      alt: "Dashboard de Fidelidapp con leads organizados",
      title: "Dashboard de Fidelidapp",
      description: "Visualiza todos tus leads, conversiones y métricas en un solo lugar"
    },
    {
      src: "/assets/demo-landing.png",
      alt: "Landing de registro de clientes",
      title: "Landing de Registro",
      description: "Los leads se registran automáticamente y quedan en tu base de datos"
    }
  ]
} = Astro.props;
---

<section class="py-20 bg-gradient-to-br from-gray-50 to-white relative overflow-hidden">
  <!-- Animated background dots -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 left-10 w-2 h-2 bg-primary/20 rounded-full animate-pulse"></div>
    <div class="absolute top-40 right-20 w-3 h-3 bg-secondary/30 rounded-full animate-ping"></div>
    <div class="absolute top-60 left-1/4 w-1 h-1 bg-primary/40 rounded-full animate-bounce"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl lg:text-4xl font-bold text-text-dark mb-6">
        {title}
      </h2>
      <p class="text-xl text-text-light max-w-3xl mx-auto">
        {subtitle}
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {screenshots.map((screenshot, index) => (
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-200 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 group">
          <!-- Screenshot placeholder with demo icon -->
          <div class="bg-gradient-to-br from-blue-100 to-indigo-100 rounded-xl p-8 mb-4 flex items-center justify-center min-h-[200px] group-hover:scale-105 transition-transform duration-300">
            {screenshot.src && screenshot.src.startsWith('/assets/') ? (
              <img 
                src={screenshot.src} 
                alt={screenshot.alt}
                class="w-full h-auto rounded-lg shadow-md"
                loading="lazy"
              />
            ) : (
              <div class="text-center">
                <div class="text-6xl mb-4">📱</div>
                <p class="text-gray-600 text-sm">Screenshot de {screenshot.title}</p>
                <p class="text-gray-500 text-xs mt-2">(Agregar imagen real)</p>
              </div>
            )}
          </div>
          
          <h3 class="text-xl font-bold text-text-dark mb-2 group-hover:text-primary transition-colors duration-300">
            {screenshot.title}
          </h3>
          <p class="text-text-light leading-relaxed">
            {screenshot.description}
          </p>
        </div>
      ))}
    </div>
    
    <!-- Video Demo CTA -->
    <div class="text-center mt-12">
      <p class="text-text-light mb-4">¿Quieres ver una demostración en vivo?</p>
      <a 
        href="#lead-form"
        class="inline-block bg-primary hover:bg-primary/90 text-white px-8 py-4 rounded-xl font-bold text-lg transition-all duration-200 transform hover:scale-105 hover:shadow-xl shadow-lg"
      >
        Agenda una demo gratuita
      </a>
    </div>
  </div>
</section>

