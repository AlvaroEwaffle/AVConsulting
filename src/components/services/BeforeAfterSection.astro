---
interface Props {
  title?: string;
  subtitle?: string;
  beforeItems?: string[];
  afterItems?: string[];
}

const {
  title = "Antes vs Después",
  subtitle = "La diferencia que hace InstaClientes en tu negocio",
  beforeItems = [
    "Respondiendo DMs manualmente todo el día",
    "Perdiendo clientes por no responder a tiempo",
    "Sin tiempo para enfocarte en tu negocio",
    "Datos de leads desorganizados",
    "Sin seguimiento automatizado",
    "Estrés constante por estar pendiente"
  ],
  afterItems = [
    "Bot trabajando 24/7 automáticamente",
    "Nunca más pierdes un cliente por no responder",
    "Tiempo libre para crecer tu negocio",
    "Base de datos organizada y actualizada",
    "Seguimiento automático de leads",
    "Tranquilidad total, el sistema funciona solo"
  ]
} = Astro.props;
---

<section class="py-20 bg-gradient-to-br from-gray-900 via-blue-900 to-indigo-900 relative overflow-hidden">
  <!-- Animated background dots -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-10 left-20 w-2 h-2 bg-white/20 rounded-full animate-pulse"></div>
    <div class="absolute top-32 right-16 w-3 h-3 bg-white/30 rounded-full animate-ping"></div>
    <div class="absolute top-64 left-1/3 w-1 h-1 bg-white/40 rounded-full animate-bounce"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">
        {title}
      </h2>
      <p class="text-xl text-white/80 max-w-3xl mx-auto">
        {subtitle}
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Before Column -->
      <div class="bg-red-500/10 backdrop-blur-sm rounded-2xl p-8 border-2 border-red-500/30">
        <div class="flex items-center mb-6">
          <div class="w-12 h-12 bg-red-500 rounded-full flex items-center justify-center mr-4">
            <span class="text-2xl">❌</span>
          </div>
          <h3 class="text-2xl font-bold text-white">Antes</h3>
        </div>
        <ul class="space-y-4">
          {beforeItems.map((item) => (
            <li class="flex items-start text-white/90">
              <span class="text-red-400 mr-3 mt-1">•</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- After Column -->
      <div class="bg-green-500/10 backdrop-blur-sm rounded-2xl p-8 border-2 border-green-500/30">
        <div class="flex items-center mb-6">
          <div class="w-12 h-12 bg-green-500 rounded-full flex items-center justify-center mr-4">
            <span class="text-2xl">✅</span>
          </div>
          <h3 class="text-2xl font-bold text-white">Después</h3>
        </div>
        <ul class="space-y-4">
          {afterItems.map((item) => (
            <li class="flex items-start text-white/90">
              <span class="text-green-400 mr-3 mt-1">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
    
    <!-- CTA -->
    <div class="text-center mt-12">
      <a 
        href="#lead-form"
        class="inline-block bg-yellow-400 hover:bg-yellow-500 text-black px-8 py-4 rounded-xl font-bold text-lg transition-all duration-200 transform hover:scale-105 hover:shadow-2xl shadow-lg"
      >
        Quiero el "Después" ahora
      </a>
    </div>
  </div>
</section>

