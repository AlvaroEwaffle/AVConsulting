---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';
import icono from '../assets/icono.png';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "VilleLabs - Desarrollo de Software y Chatbots con IA. Aplicaciones web a medida, chatbots inteligentes y automatización de procesos." } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/png" href={icono.src} />
		<title>{title} | VilleLabs</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
		
		<!-- Google Search Console Verification -->
		<meta name="google-site-verification" content="TU_CÓDIGO_DE_VERIFICACIÓN" />
		
		<!-- Open Graph Meta (para compartir en redes sociales) -->
		<meta name="author" content="VilleLabs">
		<meta name="keywords" content="desarrollo software chile, chatbots inteligentes whatsapp, automatización procesos empresariales, micro saas desarrollo chile, aplicaciones web a medida, desarrollo software a medida chile, chatbots IA chile, automatización chile, desarrollo node.js chile, desarrollo react chile">
		<meta property="og:title" content={title}>
		<meta property="og:description" content={description}>
		<meta property="og:url" content="https://villelabs.cl">
		<meta property="og:type" content="website">
		<meta property="og:image" content={icono.src}>

		<!-- Twitter Card Meta -->
		<meta name="twitter:card" content="summary_large_image">
		<meta name="twitter:title" content={title}>
		<meta name="twitter:description" content={description}>
		<meta name="twitter:image" content={icono.src}>

		<!-- Schema.org Markup - Organization -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "Organization",
					"@id": "https://villelabs.cl/#organization",
					"name": "VilleLabs",
					"alternateName": "Ville Labs",
					"url": "https://villelabs.cl",
					"logo": {
						"@type": "ImageObject",
						"url": "https://villelabs.cl/icono.png",
						"width": 512,
						"height": 512
					},
					"description": "Desarrollo de software a medida, chatbots inteligentes con IA y automatización de procesos. Construimos soluciones que generan ingresos y reducen trabajo manual.",
					"foundingDate": "2020",
					"founder": {
						"@type": "Person",
						"name": "Álvaro Villena"
					},
					"address": {
						"@type": "PostalAddress",
						"addressLocality": "Santiago",
						"addressRegion": "Región Metropolitana",
						"addressCountry": "CL"
					},
					"contactPoint": {
						"@type": "ContactPoint",
						"contactType": "customer service",
						"email": "alvrao.villena@gmail.com",
						"availableLanguage": ["Spanish", "English"]
					},
					"sameAs": [
						"https://www.linkedin.com/in/alvarovillena/",
						"https://alvarovillena.cl"
					],
					"areaServed": {
						"@type": "Place",
						"name": "Latinoamérica"
					},
					"knowsAbout": [
						"Desarrollo de software",
						"Chatbots con IA",
						"Automatización de procesos",
						"Micro-SaaS",
						"Node.js",
						"React",
						"OpenAI",
						"RAG"
					]
				},
				{
					"@type": "WebSite",
					"@id": "https://villelabs.cl/#website",
					"url": "https://villelabs.cl",
					"name": "VilleLabs - Desarrollo de Software y Chatbots con IA",
					"description": "Creamos aplicaciones y chatbots con IA que automatizan y escalan tu negocio. Construimos contigo, desde la idea hasta el deploy.",
					"publisher": {
						"@id": "https://villelabs.cl/#organization"
					},
					"potentialAction": {
						"@type": "SearchAction",
						"target": "https://villelabs.cl/contacto",
						"query-input": "required name=search_term_string"
					}
				},
				{
					"@type": "Service",
					"@id": "https://villelabs.cl/#service-software",
					"name": "Desarrollo de Software a Medida",
					"description": "Aplicaciones web a medida, portales, backoffice y paneles de control diseñados para tu operación.",
					"provider": {
						"@id": "https://villelabs.cl/#organization"
					},
					"areaServed": "Latinoamérica",
					"offers": {
						"@type": "Offer",
						"price": "2500",
						"priceCurrency": "USD",
						"priceSpecification": {
							"@type": "UnitPriceSpecification",
							"price": "2500",
							"priceCurrency": "USD",
							"valueAddedTaxIncluded": false
						}
					}
				},
				{
					"@type": "Service",
					"@id": "https://villelabs.cl/#service-chatbot",
					"name": "Chatbots Inteligentes con IA",
					"description": "Chatbots con tecnología RAG para ventas, soporte y operaciones en WhatsApp y web.",
					"provider": {
						"@id": "https://villelabs.cl/#organization"
					},
					"areaServed": "Latinoamérica",
					"offers": {
						"@type": "Offer",
						"price": "1500",
						"priceCurrency": "USD"
					}
				}
			]
		}
		</script>

		<!-- FAQ Schema for Featured Snippets -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "¿Cuánto cuesta desarrollar una aplicación a medida?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Los proyectos de aplicaciones web a medida parten desde $2,500 USD. El precio final depende de la complejidad, integraciones necesarias y alcance del proyecto. Ofrecemos cotizaciones transparentes sin costos ocultos."
					}
				},
				{
					"@type": "Question",
					"name": "¿Cuánto tiempo toma desarrollar un chatbot inteligente?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Un chatbot básico con IA puede estar listo en 2-3 semanas. Para chatbots más complejos con integraciones y entrenamiento personalizado, el tiempo puede extenderse a 4-6 semanas. Siempre trabajamos con entregables funcionales en cada ciclo."
					}
				},
				{
					"@type": "Question",
					"name": "¿Los chatbots funcionan con WhatsApp?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "Sí, nuestros chatbots se integran con WhatsApp Business API, además de web, aplicaciones móviles y APIs internas. Utilizamos tecnología RAG (Retrieval Augmented Generation) para que respondan con contexto real de tu negocio."
					}
				},
				{
					"@type": "Question",
					"name": "¿Necesito tener un equipo técnico interno?",
					"acceptedAnswer": {
						"@type": "Answer",
						"text": "No es necesario. Nosotros manejamos todo el desarrollo técnico desde la idea hasta el deploy. Solo necesitas enfocarte en tu negocio, nosotros en crear la solución. Incluimos capacitación y documentación para que puedas mantener el sistema."
					}
				}
			]
		}
		</script>

		<!-- Google Tag Manager -->
		<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
		new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
		j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
		'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
		})(window,document,'script','dataLayer','GTM-PBTHC5VK');</script>
		<!-- End Google Tag Manager -->
	</head>
	<body class="min-h-screen bg-white">
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PBTHC5VK"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	:root {
		--font-sans: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
	}
	
	html {
		font-family: var(--font-sans);
		scroll-behavior: smooth;
	}
	
	body {
		margin: 0;
		padding: 0;
		min-height: 100vh;
	}
</style>
