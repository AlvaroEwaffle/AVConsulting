<OptimizedServiceLayout title={title} description={description} serviceName="Ebook Shape Up" servicePrice="GRATIS">
  <!-- 1. Hero Section (Above the fold) -->
  <OptimizedHeroSection {...heroData} />
  
  <!-- 2. Bloque de beneficios clave -->
  <BenefitsSection {...benefitsData} />
  
  <!-- 3. Prueba social -->
  <TestimonialsSection {...testimonialsData} />
  
  <!-- 4. Sección "Cómo funciona" / Demostración -->
  <HowItWorksSection {...howItWorksData} />
  
  <!-- 5. NUEVA SECCIÓN: Banner de Garantía -->
  <GuaranteeSection {...guaranteeData} />
  
  <!-- 6. Oferta / Incentivo -->
  <OfferSection {...offerData} />
  
  <!-- 7. FAQs (Preguntas frecuentes) -->
  <FAQSection {...faqData} />
  
  <!-- 8. CTA final -->
  <FinalCTASection {...finalCTAData} />
</OptimizedServiceLayout> 