---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import HeroSection from '../../components/common/HeroSection.astro';
import ProcessSteps from '../../components/services/ProcessSteps.astro';
import TestimonialCard from '../../components/common/TestimonialCard.astro';

const title = "E-book Interactivo - Aprende Shape Up y Lanza tu Negocio Digital | Álvaro Villena";
const description = "Guía paso a paso para dar forma a tu idea y llevarla al mercado en menos de 6 semanas. Aprende Shape Up con ejemplos prácticos y casos reales.";

const processSteps = [
  {
    number: 1,
    title: "Descarga y Acceso Inmediato",
    description: "Recibe el e-book en tu email al instante. Formato PDF interactivo con enlaces y recursos adicionales.",
    icon: "📥"
  },
  {
    number: 2,
    title: "Aprende a tu Ritmo",
    description: "Contenido estructurado en módulos progresivos. Ejercicios prácticos y checklists para aplicar lo aprendido.",
    icon: "📚"
  },
  {
    number: 3,
    title: "Implementa y Lanza",
    description: "Sigue el roadmap paso a paso. En 6 semanas tendrás tu producto digital listo para el mercado.",
    icon: "🚀"
  }
];

const testimonials = [
  {
    name: "María González",
    company: "Fundadora de TechStart",
    text: "El e-book me dio la claridad que necesitaba para estructurar mi proyecto. En 5 semanas ya tenía mi MVP funcionando.",
    service: "E-book Shape Up"
  },
  {
    name: "Carlos Mendoza",
    company: "Emprendedor Digital",
    text: "Por solo $19, este e-book me ahorró meses de investigación y me dio un plan claro de acción.",
    service: "E-book Shape Up"
  },
  {
    name: "Ana Silva",
    company: "Product Manager",
    text: "Implementé Shape Up en mi startup siguiendo el e-book. Los resultados fueron inmediatos y medibles.",
    service: "E-book Shape Up"
  }
];
---

<ServiceLayout 
  title={title} 
  description={description}
  serviceName="E-book Interactivo"
  servicePrice="$19 USD"
>
  <!-- Hero Section -->
  <HeroSection
    title="E-book Interactivo: Shape Up para Emprendedores"
    subtitle="Aprende el método que usan las mejores startups para lanzar productos digitales en tiempo récord"
    description="Transforma tu idea en un plan ejecutable con Shape Up, la metodología que ha revolucionado el desarrollo de productos digitales. Este e-book te guiará paso a paso para estructurar, planificar y ejecutar tu proyecto en solo 6 semanas."
    imageSrc="/assets/ShapeUpPhoto.png"
    imageAlt="E-book Shape Up para emprendedores"
    ctaText="Comprar Ahora - $19 USD"
    ctaHref="#comprar"
  />

  <!-- What You'll Learn -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          ¿Qué Aprenderás?
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Contenido práctico y aplicable que transformará tu forma de trabajar
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
          <div class="text-4xl mb-4">🎯</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Fundamentos de Shape Up</h3>
          <p class="text-gray-600">Comprende los principios básicos y la filosofía detrás de esta metodología revolucionaria.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
          <div class="text-4xl mb-4">📋</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Planificación de Ciclos</h3>
          <p class="text-gray-600">Aprende a estructurar tu trabajo en ciclos de 6 semanas con objetivos claros y medibles.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
          <div class="text-4xl mb-4">🚫</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Evitar el Scope Creep</h3>
          <p class="text-gray-600">Técnicas para mantener el foco y evitar que tu proyecto se desborde en tiempo y recursos.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
          <div class="text-4xl mb-4">📊</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Métricas de Éxito</h3>
          <p class="text-gray-600">Define KPIs claros y aprende a medir el progreso real de tu proyecto digital.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
          <div class="text-4xl mb-4">🔄</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Iteración y Mejora</h3>
          <p class="text-gray-600">Cómo implementar feedback y mejorar continuamente tu producto basado en datos reales.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
          <div class="text-4xl mb-4">🎉</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Lanzamiento Exitoso</h3>
          <p class="text-gray-600">Estrategias para lanzar tu producto digital con confianza y maximizar el impacto.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Steps -->
  <ProcessSteps steps={processSteps} />

  <!-- Testimonials -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Lo que Dicen Nuestros Lectores
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Casos reales de emprendedores que transformaron sus proyectos con este e-book
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        {testimonials.map((testimonial) => (
          <TestimonialCard {...testimonial} />
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing and CTA -->
  <section id="comprar" class="py-20 bg-gradient-to-br from-blue-600 to-blue-800 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold mb-6">
        Invierte en tu Futuro Digital
      </h2>
      
      <div class="bg-white/10 rounded-3xl p-8 mb-8 backdrop-blur-sm">
        <div class="text-6xl font-bold mb-4">$19 USD</div>
        <p class="text-xl mb-6">Acceso inmediato y de por vida</p>
        
        <ul class="text-left max-w-md mx-auto space-y-3 mb-8">
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span>E-book PDF interactivo (120 páginas)</span>
          </li>
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span>Plantillas y checklists descargables</span>
          </li>
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span>Acceso a recursos adicionales</span>
          </li>
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span>Garantía de satisfacción de 30 días</span>
          </li>
        </ul>
      </div>
      
      <div class="space-y-4">
        <a 
          href="https://buy.stripe.com/test_link"
          class="block w-full max-w-md mx-auto bg-yellow-400 hover:bg-yellow-500 text-black px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-200 transform hover:scale-105 hover:shadow-lg"
        >
          🚀 Comprar Ahora - $19 USD
        </a>
        
        <p class="text-sm text-blue-100">
          Pago seguro con Stripe • Acceso inmediato • Sin suscripciones
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Preguntas Frecuentes
        </h2>
      </div>
      
      <div class="space-y-6">
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-lg font-semibold text-gray-900 mb-3">¿Cuándo recibo el e-book?</h3>
          <p class="text-gray-600">Inmediatamente después del pago. Recibirás un email con el enlace de descarga.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-lg font-semibold text-gray-900 mb-3">¿Puedo reembolsar si no me gusta?</h3>
          <p class="text-gray-600">Sí, tienes 30 días para solicitar un reembolso completo si no estás satisfecho.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-lg font-semibold text-gray-900 mb-3">¿Necesito conocimientos previos?</h3>
          <p class="text-gray-600">No, el e-book está diseñado para principiantes y avanzados. Incluye conceptos básicos y avanzados.</p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg">
          <h3 class="text-lg font-semibold text-gray-900 mb-3">¿El contenido se actualiza?</h3>
          <p class="text-gray-600">Sí, tendrás acceso a futuras actualizaciones del e-book sin costo adicional.</p>
        </div>
      </div>
    </div>
  </section>
</ServiceLayout> 