---
import OptimizedServiceLayout from '../../layouts/OptimizedServiceLayout.astro';
import OptimizedHeroSection from '../../components/services/OptimizedHeroSection.astro';
import LeadQualificationSection from '../../components/services/LeadQualificationSection.astro';
import BenefitsSection from '../../components/services/BenefitsSection.astro';
import TestimonialsSection from '../../components/services/TestimonialsSection.astro';
import HowItWorksSection from '../../components/services/HowItWorksSection.astro';
import GuaranteeSection from '../../components/services/GuaranteeSection.astro';
import OfferSection from '../../components/services/OfferSection.astro';
import FAQSection from '../../components/services/FAQSection.astro';
import FinalCTASection from '../../components/services/FinalCTASection.astro';

const title = "Catálogo de Servicios - Landing Page Personalizada";
