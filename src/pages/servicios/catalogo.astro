  benefits: [
    {
      icon: "🎯",
      title: "Tu Primer Vendedor Digital",
      description: "Cada visitante ve tu catálogo y piensa '¡Esto es lo que necesito!' Tu landing page será tu mejor vendedor, trabajando 24/7 para generar confianza y cerrar ventas."
    },
    {
      icon: "💼",
      title: "Deja de Perder Clientes",
