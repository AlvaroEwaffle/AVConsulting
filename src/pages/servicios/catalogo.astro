  title: "Lo que dicen nuestros clientes",
  testimonials: [
    {
      name: "María González",
      company: "Consultora de Marketing",
      text: "Álvaro creó mi catálogo de servicios en tiempo récord. La landing page es profesional y ya he recibido 3 consultas en la primera semana.",
      rating: 5
    },
    {
      name: "Carlos Mendoza",
      company: "Coach de Negocios",
      text: "Mi catálogo personalizado se ve increíble. El diseño es limpio, profesional y perfecto para mi marca. Excelente inversión.",
