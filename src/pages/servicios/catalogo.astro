  ctaText: "Completar formulario",
  ctaHref: "#lead-form"
};

// Offer Data
const offerData = {
  title: "¿Qué incluye tu catálogo digital?",
  subtitle: "Todo lo que necesitas para vender tus servicios 24/7",
