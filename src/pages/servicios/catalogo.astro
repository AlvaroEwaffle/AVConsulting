  ctaText: "Ver más detalles",
  ctaHref: "#lead-form",
  imageSrc: "/assets/LandingPhoto.png",
  socialProof: "Ya +500 empresas confían en nosotros para sus landing pages",
  clientLogos: ["/assets/icono.png"]
};

// Benefits Section Data
const benefitsData = {
  title: "¿Por qué tu negocio necesita esto AHORA?",
