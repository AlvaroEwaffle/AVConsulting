// How It Works Data
const howItWorksData = {
  title: "¿Cómo funciona?",
  subtitle: "Un proceso simple y transparente para transformar tu negocio",
  steps: [
    {
      number: 1,
      title: "Entendemos tu negocio",
      description: "Nos tomamos el tiempo para conocer tu modelo de negocio, tus clientes y tus objetivos. Escuchamos tus necesidades reales.",
      icon: "💬"
    },
    {
      number: 2,
      title: "Seteamos las herramientas",
      description: "Configuramos y activamos todas las herramientas necesarias para que tu negocio funcione de forma automática y eficiente.",
      icon: "🛠️"
    },
    {
      number: 3,
      title: "Monitoreamos en conjunto",
      description: "Trabajamos juntos para revisar resultados, hacer ajustes y optimizar continuamente. Tu éxito es nuestro éxito.",
      icon: "📊"
    }
  ],
  ctaText: "Completar formulario",
  ctaHref: "#lead-form"
};

// Guarantee Data
const guaranteeData = {
  title: "Nuestra Garantía de Entrega",
  subtitle: "No solo prometemos rapidez, la garantizamos con tu dinero de vuelta",
  guaranteeText: "Si no tienes tu catálogo listo en 48 horas, te devolvemos tu dinero completo",
