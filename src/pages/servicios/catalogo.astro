  urgency: "¡Oferta por tiempo limitado!"
};

// FAQ Data
const faqData = {
  title: "Preguntas frecuentes",
  subtitle: "Resolvemos las dudas más comunes sobre nuestro servicio",
  faqs: [
    {
      question: "¿Realmente puedo tener mi catálogo en 48 horas?",
      answer: "Sí, absolutamente. Nuestro proceso está optimizado para entregar tu catálogo completo y funcional en máximo 48 horas. Incluye diseño, desarrollo, contenido y optimización."
    },
    {
      question: "¿Qué significa 'entrega garantizada'?",
      answer: "Si no tienes tu catálogo listo en 48 horas, te devolvemos tu dinero completo. Es nuestra forma de demostrar la confianza en nuestro trabajo."
    },
    {
      question: "¿Puedo personalizar el diseño después?",
      answer: "¡Por supuesto! Te entregamos tu catálogo con un panel de administración completo donde podrás actualizar textos, imágenes, colores y estructura cuando quieras."
    },
    {
      question: "¿Incluye hosting y dominio?",
      answer: "El servicio incluye el diseño y desarrollo de tu catálogo. El hosting y dominio son servicios adicionales que podemos gestionar por ti o puedes contratar por separado."
    },
    {
      question: "¿Qué pasa si quiero hacer cambios después?",
      answer: "Incluimos 30 días de soporte técnico para ajustes menores. Para cambios mayores, ofrecemos servicios de mantenimiento a precios accesibles."
    }
  ]
};

// Final CTA Data
const finalCTAData = {
  title: "¿Listo para transformar tu negocio?",
  subtitle: "No esperes más. Tu competencia ya está vendiendo en línea mientras tú lees esto. Actúa ahora y ten tu catálogo digital vendiendo por ti en menos de 48 horas.",
  ctaText: "Completar formulario",
  ctaHref: "#lead-form",
  urgency: "¡Últimas 24 horas de descuento!",
  socialProof: "Ya +50 clientes confían en nosotros. ¿Serás el próximo?"
};
---

<OptimizedServiceLayout title={title} description={description} serviceName="Catálogo de Servicios" servicePrice="$49 USD">
  <!-- 1. Hero Section (Above the fold) -->
  <OptimizedHeroSection {...heroData} />
  
  <!-- 2. Sección "Cómo funciona" / Demostración -->
  <HowItWorksSection {...howItWorksData} />
  
  <!-- 3. Lead Qualification Form Section -->
  <div id="lead-form">
    <LeadQualificationSection serviceName="Catálogo de Servicios" />
  </div>
  
  <!-- 4. Bloque de beneficios clave -->
  <BenefitsSection {...benefitsData} />
  
  <!-- 5. Prueba social -->
  <TestimonialsSection {...testimonialsData} />
  
  <!-- 6. NUEVA SECCIÓN: Banner de Garantía -->
  <GuaranteeSection {...guaranteeData} />
  
  <!-- 7. Oferta / Incentivo -->
  <OfferSection {...offerData} />
  
  <!-- 8. FAQs (Preguntas frecuentes) -->
  <FAQSection {...faqData} />
  
  <!-- 8. CTA final -->
  <FinalCTASection {...finalCTAData} />
</OptimizedServiceLayout> 