---
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceCard from '../../components/services/ServiceCard.astro';
import HeroSection from '../../components/common/HeroSection.astro';

const title = "Servicios - Innovation Coach & Digital Product Builder | Álvaro Villena";
const description = "Descubre todos nuestros servicios para transformar ideas digitales en productos listos para vender. Desde e-books hasta gerencia fraccional.";

const services = [
  {
    title: "E-book Interactivo",
    subtitle: "Aprende Shape Up y lanza tu negocio digital",
    price: "$19 USD",
    promise: "Guía paso a paso para dar forma a tu idea y llevarla al mercado en menos de 6 semanas.",
    buttonText: "Comprar ahora",
    buttonHref: "/servicios/ebook",
    icon: "📘",
    featured: false
  },
  {
    title: "Landing Pages de Alto Impacto",
    subtitle: "Listas para convertir en 7 días",
    price: "$199 USD",
    promise: "Landing page optimizada para ventas, con garantía de conversión en la primera semana o devolvemos tu dinero.",
    buttonText: "Quiero mi landing",
    buttonHref: "/servicios/landing-pages",
    icon: "🚀",
    featured: false
  },
  {
    title: "Asesoría Shape Up",
    subtitle: "Organiza tu producto como los mejores equipos",
    price: "$499 USD",
    promise: "Te acompaño 1:1 a implementar Shape Up en tu proyecto digital, logrando foco, claridad y avances reales en ciclos de 6 semanas.",
    buttonText: "Agendar asesoría",
    buttonHref: "/servicios/asesoria",
    icon: "🎯",
    featured: true
  },
  {
    title: "Gerencia Fraccional de Innovación",
    subtitle: "Dirección de innovación a tu medida",
            price: "Desde $1,700 USD/mes",
    promise: "Lidero tus proyectos de innovación sin necesidad de contratar un gerente full-time. Flexible, ágil y orientado a resultados.",
    buttonText: "Explorar opciones",
    buttonHref: "/servicios/gerencia",
    icon: "🏢",
    featured: false
  }
];
---

<PageLayout title={title} description={description}>
  <!-- Hero Section -->
  <HeroSection
    title="Servicios que Transforman Ideas en Realidad"
    subtitle="Elige el nivel de apoyo que necesitas para llevar tu proyecto al siguiente nivel"
    description="Desde recursos educativos hasta acompañamiento ejecutivo completo. Cada servicio está diseñado para darte resultados medibles y transformaciones reales en tu proyecto digital."
    imageSrc="/assets/Covers/LandingHeroCover.png"
    imageAlt="Servicios de innovación y desarrollo digital"
    ctaText="Agenda tu Exploración Gratuita"
    ctaHref="https://calendly.com/alvarovillena/llamada-exploracion"
  />

  <!-- Services Overview -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Nuestros Servicios
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Cada servicio está diseñado para un momento específico de tu viaje emprendedor
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8">
        {services.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <!-- Service Categories -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          Categorías de Servicios
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Organizados por nivel de compromiso e inversión
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Self-Service -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
          <div class="text-4xl mb-4">📚</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Auto-Servicio</h3>
          <p class="text-gray-600 mb-6">
            Recursos educativos y herramientas que puedes usar a tu ritmo para implementar cambios inmediatos.
          </p>
          
          <div class="space-y-3 mb-6">
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-sm text-gray-700">E-book Interactivo</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-sm text-gray-700">Acceso inmediato</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-sm text-gray-700">Implementación autónoma</span>
            </div>
          </div>
          
          <div class="text-2xl font-bold text-green-600 mb-4">Desde $19 USD</div>
          <a 
            href="/servicios/ebook"
            class="block w-full bg-green-600 hover:bg-green-700 text-white text-center py-3 px-6 rounded-xl font-semibold transition-all duration-200"
          >
            Explorar Recursos
          </a>
        </div>
        
        <!-- Done-For-You -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
          <div class="text-4xl mb-4">🎯</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Hecho para Ti</h3>
          <p class="text-gray-600 mb-6">
            Servicios donde yo hago el trabajo pesado y tú recibes resultados listos para usar.
          </p>
          
          <div class="space-y-3 mb-6">
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
              <span class="text-sm text-gray-700">Landing Pages</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
              <span class="text-sm text-gray-700">Entrega en 7 días</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
              <span class="text-sm text-gray-700">Garantía de conversión</span>
            </div>
          </div>
          
          <div class="text-2xl font-bold text-blue-600 mb-4">Desde $199 USD</div>
          <a 
            href="/servicios/landing-pages"
            class="block w-full bg-blue-600 hover:bg-blue-700 text-white text-center py-3 px-6 rounded-xl font-semibold transition-all duration-200"
          >
            Ver Servicios
          </a>
        </div>
        
        <!-- Done-With-You -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
          <div class="text-4xl mb-4">👥</div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Hecho Contigo</h3>
          <p class="text-gray-600 mb-6">
            Acompañamiento personalizado donde trabajamos juntos para transformar tu proyecto y equipo.
          </p>
          
          <div class="space-y-3 mb-6">
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-purple-500 rounded-full"></div>
              <span class="text-sm text-gray-700">Asesoría Shape Up</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-purple-500 rounded-full"></div>
              <span class="text-sm text-gray-700">Gerencia Fraccional</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-purple-500 rounded-full"></div>
              <span class="text-sm text-gray-700">Transformación completa</span>
            </div>
          </div>
          
          <div class="text-2xl font-bold text-purple-600 mb-4">Desde $499 USD</div>
          <a 
            href="/servicios/asesoria"
            class="block w-full bg-purple-600 hover:bg-purple-700 text-white text-center py-3 px-6 rounded-xl font-semibold transition-all duration-200"
          >
            Explorar Opciones
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          ¿Por qué Elegir Nuestros Servicios?
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          La diferencia que marca la transformación real de tu proyecto
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🎯</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Resultados Garantizados</h3>
          <p class="text-gray-600">Si no ves resultados, te devolvemos tu dinero. Sin preguntas.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">⚡</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Implementación Rápida</h3>
          <p class="text-gray-600">Resultados en días, no en meses. Tiempo es dinero.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">👨‍💼</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Experiencia Real</h3>
          <p class="text-gray-700">Basado en casos reales, no solo teoría.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🔄</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Soporte Continuo</h3>
          <p class="text-gray-600">No te dejamos solo. Acompañamiento durante todo el proceso.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-br from-yellow-400 to-orange-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-black mb-6">
        ¿No Sabes por Dónde Empezar?
      </h2>
      <p class="text-xl text-black/80 mb-8">
        Una llamada gratuita de 20 minutos puede aclarar todo. Sin compromisos, solo claridad.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="https://calendly.com/alvarovillena/llamada-exploracion"
          class="bg-black hover:bg-gray-800 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-200 transform hover:scale-105 hover:shadow-lg"
        >
          🚀 Agenda tu Llamada Gratuita
        </a>
        
        <a 
          href="/contacto"
          class="bg-white hover:bg-gray-100 text-black px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-200 transform hover:scale-105 hover:shadow-lg border border-black"
        >
          💬 Otras Formas de Contacto
        </a>
      </div>
    </div>
  </section>
</PageLayout> 