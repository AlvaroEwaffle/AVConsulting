---

<OptimizedServiceLayout title={title} description={description} serviceName="InstaClientes" servicePrice="$49.000 CLP/mes">
  <!-- Urgency Banner at the top -->
  <section class="py-4 bg-gradient-to-br from-red-600 to-red-700 text-center sticky top-0 z-50 shadow-lg">
    <div class="max-w-4xl mx-auto px-4">
      <UrgencyCounter spotsLeft={3} showTimer={true} />
    </div>
  </section>
  
  <!-- 1. Hero Section (Above the fold) -->
  <OptimizedHeroSection {...heroData} />
  
  <!-- 2. Sección "Cómo funciona" / Demostración -->
  <HowItWorksSection {...howItWorksData} />
  
  <!-- 3. Sección Antes vs Después -->
  <BeforeAfterSection />
  
  <!-- 4. Bloque de herramientas y beneficios -->
  <BenefitsSection {...benefitsData} />
  
  <!-- 5. Demostración Visual -->
  <DemoSection />
  
  <!-- 6. Lead Qualification Form Section -->
  <div id="lead-form">
    <LeadQualificationSection serviceName="InstaClientes" />
  </div>
  
  <!-- 7. Prueba social -->
  <TestimonialsSection {...testimonialsData} />
  
  <!-- 8. Banner de Garantía -->
  <GuaranteeSection {...guaranteeData} />
  
  <!-- 9. Oferta / Incentivo -->
  <OfferSection {...offerData} />
  
  <!-- 10. FAQs (Preguntas frecuentes) -->
  <FAQSection {...faqData} />
  
  <!-- 11. CTA final -->
  <FinalCTASection {...finalCTAData} />
</OptimizedServiceLayout>

<!-- Service Schema Markup -->
<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

<!-- Breadcrumbs Schema Markup -->
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

