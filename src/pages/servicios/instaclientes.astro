// Final CTA Data
const finalCTAData = {
  title: "¿Listo para convertir tus DMs en alumnos reales?",
  subtitle: "No más perder clientes por no responder a tiempo. Tu bot trabajará 24/7 mientras tú duermes, convirtiendo DMs en leads y leads en alumnos.",
