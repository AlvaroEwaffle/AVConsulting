---
import OptimizedServiceLayout from '../../layouts/OptimizedServiceLayout.astro';
import OptimizedHeroSection from '../../components/services/OptimizedHeroSection.astro';
import LeadQualificationSection from '../../components/services/LeadQualificationSection.astro';
import BenefitsSection from '../../components/services/BenefitsSection.astro';
import TestimonialsSection from '../../components/services/TestimonialsSection.astro';
import HowItWorksSection from '../../components/services/HowItWorksSection.astro';
import GuaranteeSection from '../../components/services/GuaranteeSection.astro';
import OfferSection from '../../components/services/OfferSection.astro';
import FAQSection from '../../components/services/FAQSection.astro';
import FinalCTASection from '../../components/services/FinalCTASection.astro';
import DemoSection from '../../components/services/DemoSection.astro';
import BeforeAfterSection from '../../components/services/BeforeAfterSection.astro';
import UrgencyCounter from '../../components/common/UrgencyCounter.astro';

const title = "InstaClientes - Sistema de Captación y Fidelización desde Instagram | Álvaro Villena";
const description = "Convierte tus DMs de Instagram en alumnos reales con InstaClientes. Bot de Instagram automático 24/7, Fidelidapp completa (landing, base de datos, catálogo, agenda, puntos, email marketing), sistema de monitoreo y acompañamiento personalizado. Gratis hasta 50 clientes inscritos. Automatiza tu captación desde Instagram en Chile.";

// Service Schema for SEO
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Sistema de Captación y Fidelización desde Instagram",
  "name": "InstaClientes",
  "description": "Sistema completo para automatizar la captación y fidelización de clientes desde Instagram. Incluye bot de Instagram, Fidelidapp completa, sistema de monitoreo y acompañamiento personalizado.",
  "provider": {
    "@type": "Person",
    "name": "Álvaro Villena",
    "url": "https://alvarovillena.cl"
  },
  "areaServed": {
    "@type": "Country",
    "name": "Chile"
  },
  "offers": {
    "@type": "Offer",
    "price": "49000",
    "priceCurrency": "CLP",
    "availability": "https://schema.org/InStock",
    "description": "Gratis hasta 50 clientes inscritos"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "6",
    "bestRating": "5",
    "worstRating": "1"
  }
};

// Breadcrumbs Schema
