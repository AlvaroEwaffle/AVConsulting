---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import "../styles/global.css";
import LandingHeroCover from "../assets/Covers/LandingHeroCover.png";
---

<Layout
	title="VilleLabs – Desarrollo de Software y Chatbots con IA | Chile"
	description="Desarrollo de software a medida, chatbots inteligentes con IA y automatización de procesos. Aplicaciones web, Micro-SaaS y chatbots para WhatsApp. Santiago, Chile."
>
	<!-- Hero -->
	<section class="pt-24 pb-10 md:pt-32 md:pb-16 bg-gradient-to-b from-white to-gray-50">
		<div class="container">
			<!-- Trust Badge -->
			<div class="flex flex-wrap items-center justify-center gap-4 mb-8">
				<div class="flex items-center gap-2 text-sm text-gray-600">
					<span class="text-green-600 font-bold">✓</span>
					<span>+50 empresas confían en nosotros</span>
				</div>
				<div class="flex items-center gap-2 text-sm text-gray-600">
					<span class="text-green-600 font-bold">✓</span>
					<span>Resultados en 2-4 semanas</span>
				</div>
				<div class="flex items-center gap-2 text-sm text-gray-600">
					<span class="text-green-600 font-bold">✓</span>
					<span>Sin burocracia, sin humo</span>
				</div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
				<div class="space-y-6">
					<div>
						<h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-blue mb-4 leading-tight">
							Software a medida y chatbots con IA que generan ingresos y reducen trabajo manual
						</h1>
						<p class="text-xl md:text-2xl text-gray-700 font-medium mb-2">
							Construimos contigo, desde la idea hasta el deploy.
						</p>
						<p class="text-lg text-gray-600">
							Para founders y equipos que necesitan resultados rápidos y medibles. Menos consultoría con humo — más soluciones reales que impactan tu operación.
						</p>
					</div>
					
					<!-- Key Metrics -->
					<div class="grid grid-cols-3 gap-4 py-4 border-t border-b border-gray-200">
						<div class="text-center">
							<div class="text-2xl md:text-3xl font-bold text-brand-blue">2-4</div>
							<div class="text-xs md:text-sm text-gray-600">semanas</div>
						</div>
						<div class="text-center">
							<div class="text-2xl md:text-3xl font-bold text-brand-blue">50+</div>
							<div class="text-xs md:text-sm text-gray-600">empresas</div>
						</div>
						<div class="text-center">
							<div class="text-2xl md:text-3xl font-bold text-brand-blue">100%</div>
							<div class="text-xs md:text-sm text-gray-600">entregables</div>
						</div>
					</div>

					<div class="flex flex-col sm:flex-row gap-4">
						<a href="/contacto" class="btn btn-primary text-lg py-4 px-8 text-center min-h-[56px] flex items-center justify-center">Agenda una llamada gratuita</a>
						<a href="#proyectos" class="btn btn-outline text-lg py-4 px-8 text-center min-h-[56px] flex items-center justify-center">Ver proyectos reales</a>
					</div>

					<!-- Social Proof -->
					<div class="pt-4">
						<p class="text-sm text-gray-500 mb-2">Clientes que confían en nosotros:</p>
						<div class="flex flex-wrap items-center gap-4 text-sm text-gray-600">
							<span>Fidelidapp</span>
							<span>•</span>
							<span>Ewaffle</span>
							<span>•</span>
							<span>C4i UdeC</span>
							<span>•</span>
							<span>+47 más</span>
						</div>
					</div>
				</div>
				<div class="relative">
					<Image
						src={LandingHeroCover}
						alt="VilleLabs - Desarrollo y chatbots"
						class="rounded-2xl shadow-xl"
						width={600}
						height={400}
					/>
				</div>
			</div>
		</div>
	</section>

	<!-- Pricing Transparency -->
	<section class="py-16 md:py-20 bg-brand-blue text-white">
		<div class="container">
			<div class="max-w-4xl mx-auto text-center">
				<h2 class="text-3xl md:text-4xl font-bold mb-4">Inversión transparente</h2>
				<p class="text-xl text-blue-100 mb-8">Precios claros desde el inicio. Sin sorpresas, sin costos ocultos.</p>
				<div class="bg-white/10 backdrop-blur-sm p-6 rounded-2xl border border-white/20">
					<p class="text-lg mb-4">¿Necesitas una cotización personalizada?</p>
					<a href="/contacto" class="btn bg-white text-brand-blue hover:bg-blue-50">Solicitar cotización gratuita</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Qué hacemos -->
	<section id="que-hacemos" class="py-16 md:py-20">
		<div class="container">
			<h2 class="text-3xl font-bold text-brand-blue mb-8 text-center">Qué hacemos</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
				<div class="bg-white p-8 rounded-2xl shadow-lg border">
					<div class="flex items-center gap-3 mb-3">
						<span class="text-2xl">🧰</span>
						<h3 class="text-xl font-bold text-brand-blue">Aplicaciones web a la medida</h3>
					</div>
					<p class="text-gray-700 mb-4">Portales, backoffice y paneles de control diseñados para tu operación.</p>
					<ul class="list-disc list-inside text-gray-600 space-y-1">
						<li>Roles, permisos y auditoría</li>
						<li>Integraciones: Stripe, Zapier, Slack, CRMs</li>
						<li>UX enfocada en productividad</li>
					</ul>
				</div>
				<div class="bg-white p-8 rounded-2xl shadow-lg border">
					<div class="flex items-center gap-3 mb-3">
						<span class="text-2xl">🤖</span>
						<h3 class="text-xl font-bold text-brand-blue">Chatbots inteligentes</h3>
					</div>
					<p class="text-gray-700 mb-4">Ventas, soporte y operaciones en WhatsApp y web con contexto real de tu negocio.</p>
					<ul class="list-disc list-inside text-gray-600 space-y-1">
						<li>RAG con tus documentos y políticas</li>
						<li>Formularios conversacionales y acciones</li>
						<li>Panel con métricas y calidad de respuestas</li>
					</ul>
				</div>
				<div class="bg-white p-8 rounded-2xl shadow-lg border">
					<div class="flex items-center gap-3 mb-3">
						<span class="text-2xl">⚙️</span>
						<h3 class="text-xl font-bold text-brand-blue">Automatización de procesos</h3>
					</div>
					<p class="text-gray-700 mb-4">De punta a punta: captación → validación → notificación → reporte.</p>
					<ul class="list-disc list-inside text-gray-600 space-y-1">
						<li>Conectores API/DB y webhooks</li>
						<li>Tareas programadas y orquestación</li>
						<li>Reducción de errores y tiempos de ciclo</li>
					</ul>
				</div>
				<div class="bg-white p-8 rounded-2xl shadow-lg border">
					<div class="flex items-center gap-3 mb-3">
						<span class="text-2xl">🚀</span>
						<h3 class="text-xl font-bold text-brand-blue">Micro‑SaaS para founders</h3>
					</div>
					<p class="text-gray-700 mb-4">Desde MVP hasta primera venta, priorizando lo esencial.</p>
					<ul class="list-disc list-inside text-gray-600 space-y-1">
						<li>MVP en 2–4 semanas</li>
						<li>Pagos y suscripciones</li>
						<li>Analítica, onboarding y soporte</li>
					</ul>
				</div>
				<div class="bg-white p-8 rounded-2xl shadow-lg border md:col-span-2">
					<div class="flex items-center gap-3 mb-3">
						<span class="text-2xl">☁️</span>
						<h3 class="text-xl font-bold text-brand-blue">Infraestructura moderna</h3>
					</div>
					<p class="text-gray-700 mb-4">Despliegues rápidos y costo‑eficientes.</p>
					<ul class="list-disc list-inside text-gray-600 grid grid-cols-1 md:grid-cols-3 gap-1">
						<li>Cloudflare, Railway, Vercel</li>
						<li>CI/CD, entornos y rollback</li>
						<li>Observabilidad, logs y costos</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- Por qué trabajar con nosotros -->
	<section class="py-16 md:py-20 bg-gray-50">
		<div class="container">
			<h2 class="text-3xl font-bold text-brand-blue text-center mb-10">¿Por qué trabajar con nosotros?</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
				<div class="bg-white p-8 rounded-2xl shadow-lg border">
					<div class="flex items-center gap-3 mb-2">
						<span class="text-2xl">🤝</span>
						<h3 class="text-lg font-bold text-brand-blue">Enfoque humano + técnico</h3>
					</div>
					<p class="text-gray-700 mb-3">Hablamos negocio y resolvemos con ingeniería.</p>
					<ul class="list-disc list-inside text-gray-600 space-y-1">
						<li>Traducción objetivos → soluciones viables</li>
						<li>KPI y ROI considerados desde el diseño</li>
						<li>Equipo involucrado y alineado</li>
					</ul>
				</div>
				<div class="bg-white p-8 rounded-2xl shadow-lg border">
					<div class="flex items-center gap-3 mb-2">
						<span class="text-2xl">⚡</span>
						<h3 class="text-lg font-bold text-brand-blue">Construcción rápida</h3>
					</div>
					<p class="text-gray-700 mb-3">Ciclos de 2–4 semanas con entregables reales.</p>
					<ul class="list-disc list-inside text-gray-600 space-y-1">
						<li>Demo funcional en cada ciclo</li>
						<li>Prioridad por impacto, no por lista infinita</li>
						<li>Feedback continuo, menos retrabajo</li>
					</ul>
				</div>
				<div class="bg-white p-8 rounded-2xl shadow-lg border">
					<div class="flex items-center gap-3 mb-2">
						<span class="text-2xl">🧭</span>
						<h3 class="text-lg font-bold text-brand-blue">Acompañamiento real</h3>
					</div>
					<p class="text-gray-700 mb-3">Te ayudamos a priorizar y decidir con datos.</p>
					<ul class="list-disc list-inside text-gray-600 space-y-1">
						<li>Roadmap, riesgos y focos por ciclo</li>
						<li>Métricas de adopción y uso</li>
						<li>Canales claros de comunicación</li>
					</ul>
				</div>
				<div class="bg-white p-8 rounded-2xl shadow-lg border">
					<div class="flex items-center gap-3 mb-2">
						<span class="text-2xl">🎯</span>
						<h3 class="text-lg font-bold text-brand-blue">Desarrollo con propósito</h3>
					</div>
					<p class="text-gray-700 mb-3">Cada feature tiene un objetivo de negocio.</p>
					<ul class="list-disc list-inside text-gray-600 space-y-1">
						<li>Hipótesis y resultado esperado</li>
						<li>Métricas de éxito claras</li>
						<li>Se desactiva lo que no rinde</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- Chatbots Inteligentes -->
	<section class="py-16 md:py-20" style="background-color: #2175a1;">
		<div class="container">
			<h2 class="text-3xl font-bold text-white text-center mb-6">Chatbots Inteligentes para tu negocio</h2>
			<p class="text-center text-lg text-blue-100 max-w-3xl mx-auto mb-10">Chatbots entrenados con tus documentos, políticas y procesos para responder con contexto, accionar tareas y escalar atención.</p>
			<div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6 text-white mb-6">
				<div class="bg-white/10 backdrop-blur-sm p-5 rounded-xl">
					<h3 class="font-semibold mb-2">Casos de uso</h3>
					<ul class="space-y-2 text-white/90">
						<li>Captura y calificación de leads</li>
						<li>Agendamiento de horas y coordinación</li>
						<li>Soporte con base de conocimientos</li>
						<li>Consulta de estado de pedidos y postventa</li>
					</ul>
				</div>
				<div class="bg-white/10 backdrop-blur-sm p-5 rounded-xl">
					<h3 class="font-semibold mb-2">Integración y tecnología</h3>
					<ul class="space-y-2 text-white/90">
						<li>Canales: WhatsApp, web, apps y APIs internas</li>
						<li>Stack: OpenAI, RAG, embeddings, Node.js, SQL/MongoDB, LangChain</li>
						<li>Medición: paneles con conversaciones, calidad y conversiones</li>
					</ul>
				</div>
			</div>
			<ul class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-3xl mx-auto text-white">
				<li class="bg-white/10 backdrop-blur-sm p-4 rounded-xl">Responde preguntas con información de tu empresa (documentos actualizados)</li>
				<li class="bg-white/10 backdrop-blur-sm p-4 rounded-xl">Agenda, registra leads o procesa solicitudes automáticamente</li>
				<li class="bg-white/10 backdrop-blur-sm p-4 rounded-xl">Analiza PDFs y políticas para respuestas precisas</li>
				<li class="bg-white/10 backdrop-blur-sm p-4 rounded-xl">Se integra a WhatsApp, web y sistemas internos</li>
			</ul>
			<div class="text-center mt-10">
				<a href="/contacto" class="btn bg-white text-brand-blue hover:bg-blue-50">Quiero un chatbot para mi empresa</a>
			</div>
		</div>
	</section>

	<!-- Aplicaciones a medida -->
	<section class="py-16 md:py-20">
		<div class="container">
			<h2 class="text-3xl font-bold text-brand-blue text-center mb-8">Aplicaciones a medida</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-5xl mx-auto">
				<ul class="space-y-3 bg-white p-6 rounded-2xl shadow">
					<li>Dashboards de gestión</li>
					<li>Sistemas de reservas o agendas</li>
					<li>Plataformas de capacitación</li>
					<li>Backoffice y herramientas internas</li>
					<li>Micro‑SaaS listos para vender</li>
					<li>Automatizaciones (envíos, reportes, notificaciones)</li>
                        </ul>
				<div class="bg-gray-50 p-6 rounded-2xl border">
					<h3 class="text-lg font-semibold text-brand-blue mb-2">Qué consigues</h3>
					<ul class="space-y-2 text-gray-700">
						<li>Menos planillas y tareas manuales</li>
						<li>Visibilidad de punta a punta en una sola pantalla</li>
						<li>Menos errores y más cumplimiento</li>
						<li>Equipos enfocados en lo importante</li>
                        </ul>
					<p class="mt-4 text-gray-700">Stack moderno: Node.js, React, Astro, Tailwind, SQL/Mongo, Cloudflare Pages, Railway.</p>
                </div>
            </div>
        </div>
    </section>

	<!-- Cómo trabajamos -->
	<section class="bg-gray-50 py-16 md:py-24">
		<div class="container">
			<h2 class="text-3xl font-bold text-brand-blue text-center mb-12">Cómo trabajamos</h2>
			<div class="max-w-3xl mx-auto space-y-6">
				<div class="flex items-start gap-4 bg-white p-6 rounded-2xl shadow">
					<div class="flex-shrink-0 w-10 h-10 bg-brand-blue text-white rounded-full flex items-center justify-center font-bold">1</div>
					<div>
						<h3 class="text-xl font-bold text-brand-blue mb-1">Definir</h3>
						<p class="text-gray-700">Alineamos objetivos y entendemos tu proceso actual para detectar oportunidades de impacto.</p>
			</div>
		</div>
				<div class="flex items-start gap-4 bg-white p-6 rounded-2xl shadow">
					<div class="flex-shrink-0 w-10 h-10 bg-brand-blue text-white rounded-full flex items-center justify-center font-bold">2</div>
					<div>
						<h3 class="text-xl font-bold text-brand-blue mb-1">Especificar</h3>
						<p class="text-gray-700">Plan técnico claro y acotado: alcance, integraciones y entregables por ciclo (Shape Up).</p>
                    </div>
                </div>
				<div class="flex items-start gap-4 bg-white p-6 rounded-2xl shadow">
					<div class="flex-shrink-0 w-10 h-10 bg-brand-blue text-white rounded-full flex items-center justify-center font-bold">3</div>
					<div>
						<h3 class="text-xl font-bold text-brand-blue mb-1">Construir</h3>
						<p class="text-gray-700">Desarrollo en ciclos de 2–4 semanas con demos funcionales y feedback continuo.</p>
        </div>
				</div>
				<div class="flex items-start gap-4 bg-white p-6 rounded-2xl shadow">
					<div class="flex-shrink-0 w-10 h-10 bg-brand-blue text-white rounded-full flex items-center justify-center font-bold">4</div>
					<div>
						<h3 class="text-xl font-bold text-brand-blue mb-1">Iterar</h3>
						<p class="text-gray-700">Medimos, ajustamos y escalamos lo que funciona. Proceso transparente, sin burocracia.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Casos y proyectos reales -->
	<section id="proyectos" class="py-16 md:py-24 bg-gray-50">
		<div class="container">
					<div class="text-center mb-12">
						<h2 class="text-3xl md:text-4xl font-bold text-brand-blue mb-4">Casos y proyectos reales</h2>
						<p class="text-xl text-gray-600 max-w-3xl mx-auto">Proyectos reales con resultados medibles. Construimos soluciones que generan valor desde el primer día.</p>
						<div class="mt-6 flex flex-wrap justify-center gap-4 text-sm text-gray-600">
							<a href="#que-hacemos" class="hover:text-brand-blue transition-colors">Ver servicios →</a>
							<a href="#testimonios" class="hover:text-brand-blue transition-colors">Ver testimonios →</a>
							<a href="#faq" class="hover:text-brand-blue transition-colors">Ver FAQ →</a>
						</div>
					</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
				<!-- Fidelidapp -->
				<div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-300">
					<div class="relative h-48 bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center">
						<span class="text-6xl">💳</span>
					</div>
					<div class="p-6">
						<div class="flex items-center justify-between mb-3">
							<h3 class="text-xl font-bold text-brand-blue">Fidelidapp</h3>
							<span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full font-semibold">SaaS</span>
						</div>
						<p class="text-gray-700 mb-4 font-medium">SaaS de fidelización con puntos y campañas omnicanal</p>
						<div class="space-y-2 mb-4">
							<div class="flex items-center gap-2 text-sm text-gray-600">
								<span class="text-green-600 font-bold">-40%</span>
								<span>trabajo manual</span>
							</div>
							<div class="flex items-center gap-2 text-sm text-gray-600">
								<span class="text-green-600 font-bold">↑</span>
								<span>Campañas más precisas</span>
							</div>
						</div>
						<div class="flex flex-wrap gap-2 mb-4">
							<span class="text-xs bg-gray-100 text-gray-700 px-2 py-1 rounded">Node.js</span>
							<span class="text-xs bg-gray-100 text-gray-700 px-2 py-1 rounded">React</span>
							<span class="text-xs bg-gray-100 text-gray-700 px-2 py-1 rounded">WhatsApp API</span>
						</div>
						<a href="https://www.fidelidapp.cl/" target="_blank" rel="noopener" class="inline-flex items-center text-brand-blue font-semibold hover:text-blue-700 transition-colors">
							Ver sitio en vivo
							<svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
							</svg>
						</a>
					</div>
				</div>

				<!-- Ewaffle -->
				<div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-300">
					<div class="relative h-48 bg-gradient-to-br from-purple-500 to-purple-700 flex items-center justify-center">
						<span class="text-6xl">🎓</span>
					</div>
					<div class="p-6">
						<div class="flex items-center justify-between mb-3">
							<h3 class="text-xl font-bold text-brand-blue">Ewaffle</h3>
							<span class="text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded-full font-semibold">E-learning</span>
						</div>
						<p class="text-gray-700 mb-4 font-medium">Soluciones e-learning completas: LMS, cursos gamificados, chatbots IA</p>
						<div class="space-y-2 mb-4">
							<div class="flex items-center gap-2 text-sm text-gray-600">
								<span class="text-green-600 font-bold">+50</span>
								<span>empresas confían</span>
							</div>
							<div class="flex items-center gap-2 text-sm text-gray-600">
								<span class="text-green-600 font-bold">400+</span>
								<span>cursos transformados</span>
							</div>
							<div class="flex items-center gap-2 text-sm text-gray-600">
								<span class="text-green-600 font-bold">40%</span>
								<span>mejora en calidad</span>
							</div>
						</div>
						<div class="flex flex-wrap gap-2 mb-4">
							<span class="text-xs bg-gray-100 text-gray-700 px-2 py-1 rounded">LMS</span>
							<span class="text-xs bg-gray-100 text-gray-700 px-2 py-1 rounded">SCORM</span>
							<span class="text-xs bg-gray-100 text-gray-700 px-2 py-1 rounded">OpenAI RAG</span>
							<span class="text-xs bg-gray-100 text-gray-700 px-2 py-1 rounded">Gamificación</span>
						</div>
						<a href="https://ewaffle.cl/" target="_blank" rel="noopener" class="inline-flex items-center text-brand-blue font-semibold hover:text-blue-700 transition-colors">
